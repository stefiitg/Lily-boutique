<!DOCTYPE html>
<html  lang="ro">
    <head>
        <meta name="description" content="Cofetaria Dulcelind ofera prajituri, torturi, produse de patiserie cu optiunea de achizitie online si livrare prin curier.">
        <meta name="keywords" content="cofetarie, Dulcelind, prajituri, torturi, dulce, pateuri, produse,<%- locals.prod.nume %>">
        
        <title>Cofetăria Dulcelind - <%- locals.prod.nume %></title>
        <%- include("../fragmente/head") %>     
        <link href="/resurse/css/produs.css" type="text/css" rel="stylesheet" />
    </head>

        <%- include("../fragmente/header") %>
    <main>
        <section>
            <h2>Pagină produs</h2>
               <article id="art-produs">
                    <h3><span class="nume"><%- locals.prod.nume %></span></h3>
                    <p>Preț: <span class="pret"><%- locals.prod.pret %> lei</span></p>
                    <p>Descriere: <span class="descriere"><%- locals.prod.descriere %></span></p>
                    <p>Mărime: <span class="marime"><%- locals.prod.marime %></span></p>
                    <p>Culoare: <span class="culoare"><%- String(locals.prod.culoare).replace(/[{}]/g, '').replace(/,/g, ', ') %></span></p>
                    <p>Ocazie: <span class="ocazie"><%- locals.prod.ocazie %></span></p>
                    <p>Categorie: <span class="categorie"><%- locals.prod.categorie %></span></p>
                    <p>Materiale: <span class="materiale"><%- String(locals.prod.materiale).replace(/[{}]/g, '').replace(/,/g, ', ') %></span></p>                    <p>Ediție limitată: <span class="editie"><%- locals.prod.editie_limitata ? 'Da' : 'Nu' %></span></p>
                    <p>Data adăugare: <span class="data_adaugare"><%- new Date(locals.prod.data_adaugare).toLocaleDateString('ro-RO') %></span></p>
                    
                    <figure class="imag-produs">
                        <img src="/resurse/imagini/<%- locals.prod.imagine %>" alt="Imagine <%- locals.prod.nume %>" />
                    </figure>    
                </article>
            
        </section>
    </main>

    <%- include("../fragmente/footer") %>
    </body>
</html>